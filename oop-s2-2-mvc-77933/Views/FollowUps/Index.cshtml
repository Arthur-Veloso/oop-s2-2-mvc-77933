@model IEnumerable<FoodSafety.domain.Models.FollowUp>

@{
    ViewData["Title"] = "Index";
}

<h1>FollowUp</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>

<form method="get" class="row g-2 mb-3">

    <div class="col-md-4">
        <select name="premisesId" class="form-control" asp-items="ViewBag.Premises">
            <option value="">All Premises</option>
        </select>
    </div>

    <div class="col-md-3">
        <select name="status" class="form-control">
            <option value="">All Status</option>
            <option value="Open">Open</option>
            <option value="Closed">Closed</option>
        </select>
    </div>

    <div class="col-md-3 d-flex align-items-center">
        <input type="checkbox" name="overdue" value="true" class="form-check-input me-2" />
        <label class="form-check-label">Overdue Only</label>
    </div>

    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Filter</button>
    </div>

</form>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Inspection)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DueDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ClosedDate)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                    @Html.DisplayFor(modelItem => item.Inspection.Premises.Name)
            </td>
            <td>
                @item.DueDate.ToString("dd MMM yyyy")
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Status)
            </td>
            <td>
                @(item.ClosedDate.HasValue
                               ? item.ClosedDate.Value.ToString("dd MMM yyyy")
                                : "-")
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
