@model IEnumerable<FoodSafety.domain.Models.Inspection>

@{
    ViewData["Title"] = "Index";
}

<h1>Inspection</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<form method="get" class="row g-2 mb-3">

    <div class="col-md-4">
        <select name="premisesId" class="form-control" asp-items="ViewBag.Premises">
            <option value="">All Premises</option>
        </select>
    </div>

    <div class="col-md-4">
        <select name="outcome" class="form-control">
            <option value="">All Outcomes</option>
            <option value="Pass">Pass</option>
            <option value="Fail">Fail</option>
        </select>
    </div>

    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Filter</button>
    </div>

</form>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Premises)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.InspectionDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Score)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Outcome)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Notes)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Premises.Name)
            </td>
                <td>
                    @item.InspectionDate.ToString("dd MMM yyyy")
                </td>
            <td>
                @Html.DisplayFor(modelItem => item.Score)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Outcome)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Notes)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
