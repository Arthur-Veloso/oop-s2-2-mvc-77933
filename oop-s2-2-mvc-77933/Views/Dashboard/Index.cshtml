@{
}
<h2>Dashboard</h2>

<form method="get" class="mb-3 d-flex gap-2">

    <select name="town" class="form-control">
        <option value="">All Towns</option>
        @foreach (var t in ViewBag.Towns)
        {
            <option value="@t" selected="@(t == ViewBag.SelectedTown)">
                @t
            </option>
        }
    </select>

    <select name="riskRating" class="form-control">
        <option value="">All Risk Levels</option>
        <option value="Low" selected="@(ViewBag.SelectedRisk?.ToString() == "Low")">Low</option>
        <option value="Medium" selected="@(ViewBag.SelectedRisk?.ToString() == "Medium")">Medium</option>
        <option value="High" selected="@(ViewBag.SelectedRisk?.ToString() == "High")">High</option>
    </select>

    <button type="submit" class="btn btn-primary">Search</button>

</form>

<div>
    <h4>Inspections this month: @ViewBag.InspectionsThisMonth</h4>
    <h4>Failed inspections this month: @ViewBag.FailedThisMonth</h4>
    <h4>Overdue follow-ups: @ViewBag.OverdueFollowUps</h4>
</div>