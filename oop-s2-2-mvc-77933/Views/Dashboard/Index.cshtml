@{
}
<h1 class="mb-4">📊 Dashboard</h1>

<form method="get" class="row g-2 mb-4">

    <div class="col-md-4">
        <select name="town" class="form-control">
            <option value="">All Towns</option>
            @foreach (var town in ViewBag.Towns)
            {
                <option value="@town">@town</option>
            }
        </select>
    </div>

    <div class="col-md-4">
        <select name="riskRating" class="form-control">
            <option value="">All Risk Levels</option>
            <option value="Low">Low</option>
            <option value="Medium">Medium</option>
            <option value="High">High</option>
        </select>
    </div>

    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Search</button>
    </div>

</form>

<div class="row mt-4">

    <div class="col-md-4">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body">
                <h5 class="card-title">Inspections This Month</h5>
                <h2>@ViewBag.InspectionsThisMonth</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-white bg-danger mb-3">
            <div class="card-body">
                <h5 class="card-title">Failed Inspections</h5>
                <h2>@ViewBag.FailedThisMonth</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-dark bg-warning mb-3">
            <div class="card-body">
                <h5 class="card-title">Overdue Follow-Ups</h5>
                <h2>@ViewBag.OverdueFollowUps</h2>
            </div>
        </div>
    </div>

</div>